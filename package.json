{
	"name": "promo-studio",
	"version": "1.0.0",
	"description": "Multi-agent commerce demo: Codex, Pi, and Cursor SDK harnesses for isolated storefront variants with shared validation and receipts",
	"private": true,
	"engines": {
		"node": "^22.19.0 || >=24 <27"
	},
	"scripts": {
		"test": "tsx scripts/ensure-sqlite-database.ts test.db && DATABASE_URL=file:./test.db prisma db push --force-reset --accept-data-loss && DATABASE_URL=file:./test.db tsx prisma/seed.ts && DATABASE_URL=file:./test.db vitest run",
		"dev": "next dev --webpack",
		"dev:turbo": "next dev",
		"build": "prisma generate && next build",
		"start": "next start",
		"setup": "npm run db:push && npm run seed",
		"ci": "npm run validate",
		"agent:doctor": "tsx scripts/agent-doctor.ts",
		"agent:harness-e2e": "tsx scripts/agent-harness-e2e.ts",
		"agent:harness-http-e2e": "tsx scripts/agent-harness-http-e2e.ts",
		"codex:doctor": "tsx scripts/codex-doctor.ts",
		"pi:doctor": "tsx scripts/pi-doctor.ts",
		"cursor:doctor": "tsx scripts/cursor-doctor.ts",
		"cursor:smoke": "tsx scripts/cursor-smoke-gate.ts",
		"codex:smoke": "tsx scripts/codex-smoke-gate.ts",
		"codex:check": "tsx scripts/check-codex.ts",
		"codex:app-smoke": "tsx scripts/codex-app-smoke.ts",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "prisma generate && next typegen && tsc --noEmit",
		"seed": "DATABASE_URL=file:./dev.db tsx prisma/seed.ts",
		"db:push": "tsx scripts/ensure-sqlite-database.ts dev.db && DATABASE_URL=file:./dev.db prisma db push --force-reset --accept-data-loss && DATABASE_URL=file:./dev.db prisma generate",
		"validate": "npm run db:push && npm run seed && npm run typecheck && npm run format:check && npm run lint && npm run test && npm run build",
		"reset:workspaces": "tsx scripts/reset-workspaces.ts",
		"runs:worker": "tsx scripts/run-variant-worker.ts",
		"demo:zip": "tsx scripts/package-demo.ts",
		"postinstall": "prisma generate"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"@cursor/sdk": "1.0.23",
		"@earendil-works/pi-coding-agent": "^0.80.10",
		"@openai/codex-sdk": "^0.144.5",
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.11.1",
		"next": "^16.2.10",
		"prisma": "^7.8.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"jsdom": "^29.1.1",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"overrides": {
		"postcss": "8.5.19",
		"@hono/node-server": "1.19.14",
		"@connectrpc/connect-node": {
			"undici": "^6.27.0"
		},
		"hono": "^4.12.30",
		"undici": "^7.28.0"
	},
	"packageManager": "npm@11.18.0",
	"allowScripts": {
		"@google/genai@1.52.0": true,
		"@prisma/engines@7.8.0": true,
		"better-sqlite3@12.11.1": true,
		"esbuild@0.28.1": true,
		"fsevents@2.3.3": true,
		"prisma@7.8.0": true,
		"protobufjs@7.6.4": true,
		"sharp@0.34.5": true
	}
}
