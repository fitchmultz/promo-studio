DATABASE_URL="file:./dev.db"
PROJECT_ROOT=""
SESSION_SECRET="replace-with-a-long-random-local-secret"

# Multi-agent defaults (studio gear menu overrides per run)
# AGENT_CORE: codex | pi | cursor
AGENT_CORE="codex"
CODEX_AUTH_MODE="auto"
CODEX_RUNTIME="sdk"
CODEX_MODEL="gpt-5.5"
CODEX_REASONING_EFFORT="low"
PI_MODEL=""
CURSOR_MODEL="composer-2.5-fast"
CURSOR_API_KEY=""
CURSOR_TIMEOUT_MS="300000"
# Pi model ref: provider/model or provider/model:thinking (e.g. cursor/composer-2.5 or openai-codex/gpt-5.5:low)
CODEX_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
CODEX_TIMEOUT_MS="300000"
PI_TIMEOUT_MS="300000"
COOKIE_SECURE="false"
