{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!**/out",
			"!**/build",
			"!**/next-env.d.ts",
			"!**/package-lock.json",
			"!**/codex-workspaces",
			"!**/agent-workspaces",
			"!**/templates/storefront/dist",
			"!**/templates/storefront/node_modules"
		]
	}
}
